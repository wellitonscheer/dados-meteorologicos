# Copie para .env e ajuste se quiser: cp .env.example .env

# Ambiente: "development" (default) ou "production". Em production o backend
# ABORTA o startup se SECRET_KEY/SEED_PASSWORD ainda estiverem nos defaults.
APP_ENV=development

# Banco de dados Postgres
# Em produção, use uma senha forte (evite caracteres especiais de URL como @ : /).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Chave usada para assinar os tokens JWT. OBRIGATÓRIO trocar em produção; gere com:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-secret-change-me

# Usuário administrador semeado no primeiro startup. Em produção, defina uma
# senha forte (o default "admin" é bloqueado quando APP_ENV=production).
SEED_USERNAME=admin
SEED_PASSWORD=admin

# Exposição pública (produção). ALLOWED_HOSTS = domínio do túnel (Host aceito);
# FRONTEND_ORIGIN = URL pública https do app (CORS). Em dev pode deixar em branco.
#   ALLOWED_HOSTS=app.exemplo.com
#   FRONTEND_ORIGIN=https://app.exemplo.com
ALLOWED_HOSTS=*
FRONTEND_ORIGIN=http://localhost:5173

# Chave da API do Gemini (google-genai) — usada pelo chat
GEMINI_API_KEY=

# Nome da aba (worksheet) da planilha lida pelo agente (padrão: Sheet1).
GOOGLE_SHEETS_WORKSHEET_NAME=Sheet1

# Nome da aba (worksheet) da 2ª planilha, de produtores/propriedades (padrão: Sheet1).
GOOGLE_SHEETS_PROPRIEDADES_WORKSHEET_NAME=Sheet1

# Chave da Point Forecast API do Windy (https://api.windy.com/point-forecast) — tool de previsão do tempo
WINDY_API_KEY=

# ID da agenda do Google Calendar lida pela tool do agente (somente leitura).
# Configurações da agenda > Integrar agenda > "ID da agenda"
# (ex.: xxxxxxxx@group.calendar.google.com). A agenda precisa estar
# compartilhada com o e-mail da conta de serviço do Google.
GOOGLE_CALENDAR_ID=
