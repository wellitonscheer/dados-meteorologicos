# Copie para .env e ajuste se quiser: cp .env.example .env

# Banco de dados Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Chave usada para assinar os tokens JWT (troque em produção)
SECRET_KEY=dev-secret-change-me

# Credenciais do usuário semeado no startup (login inicial). Troque em produção.
# Alterar a senha aqui e recriar o backend já atualiza o usuário existente.
SEED_USERNAME=admin
SEED_PASSWORD=admin

# --- Exposição pública via túnel (Cloudflare) ---
# Preencher na MÁQUINA que roda o túnel + app. Em dev local, deixe os defaults.
# Ex. de valores para o túnel:
#   VITE_ALLOWED_HOSTS=agente.caie.dev
#   VITE_API_URL=https://api.agente.caie.dev
#   FRONTEND_ORIGIN=https://agente.caie.dev
VITE_ALLOWED_HOSTS=
VITE_API_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:5173

# Chave da API do Gemini (google-genai) — usada pelo chat
GEMINI_API_KEY=

# Nome da aba (worksheet) da planilha lida pelo agente (padrão: Sheet1).
GOOGLE_SHEETS_WORKSHEET_NAME=Sheet1

# Nome da aba (worksheet) da 2ª planilha, de produtores/propriedades (padrão: Sheet1).
GOOGLE_SHEETS_PROPRIEDADES_WORKSHEET_NAME=Sheet1

# Chave da Point Forecast API do Windy (https://api.windy.com/point-forecast) — tool de previsão do tempo
WINDY_API_KEY=

# ID da agenda do Google Calendar lida pela tool do agente (somente leitura).
# Configurações da agenda > Integrar agenda > "ID da agenda"
# (ex.: xxxxxxxx@group.calendar.google.com). A agenda precisa estar
# compartilhada com o e-mail da conta de serviço do Google.
GOOGLE_CALENDAR_ID=
